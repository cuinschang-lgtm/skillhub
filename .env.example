# SkillHub Environment Variables
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://skillhub:skillhub_dev@localhost:5432/skillhub

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-this-to-a-random-string
JWT_EXPIRE_MINUTES=10080

# Storage
STORAGE_DIR=./storage

# LLM (platform default keys, optional)
DEEPSEEK_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# OCR
MINERU_TOKEN=

# Email (for verification codes)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
